# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ZERO_TWO_API_KEY: API Key for the Zero Two APIs (e.g. onnx-ia-key)
ZERO_TWO_API_KEY="onnx-ia-key"

# API_KEY: Main API Key for the proxy to use when connecting to Zero Two APIs
API_KEY="onnx-ia-key"

# ZERO_TWO_API_BASE_URL: Base URL for Zero Two APIs
ZERO_TWO_API_BASE_URL="https://zero-two-apis.store"

# YT_API_BASE_URL: Fast and robust base URL specifically for YouTube downloader & parser APIs
YT_API_BASE_URL="https://yt-api.zero-two-apis.store"

# PostgreSQL Database Connection String (e.g. postgresql://user:password@host:port/database)
DATABASE_URL=""

# JWT Secret for encoding/decoding user session tokens
JWT_SECRET=""

# MercadoPago Access Token for checkout
MERCADOPAGO_ACCESS_TOKEN=APP_USR-4691327005261909-070108-11a727d082a2d8674da55f802d11f53a-543280425

# SMTP Settings for sending emails
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="noreply@attodownloads.com"
